{
  "name": "co-bridge",
  "displayName": "CoBridge",
  "description": "Seamlessly sync your web AI conversations to your local IDE.",
  "version": "1.0.3",
  "publisher": "windfall",
  "repository": {
    "type": "git",
    "url": "https://github.com/Winddfall/CoBridge.git"
  },
  "license": "MIT",
  "icon": "public/icon.png",
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "Gemini Voyager",
    "Gemini",
    "Sync",
    "Context",
    "Productivity"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cobridge.showMenu",
        "title": "CoBridge: Show Menu"
      },
      {
        "command": "cobridge.startServer",
        "title": "CoBridge: Start Server"
      },
      {
        "command": "cobridge.stopServer",
        "title": "CoBridge: Stop Server"
      },
      {
        "command": "cobridge.openContext",
        "title": "CoBridge: Open Context File"
      },
      {
        "command": "cobridge.clearContext",
        "title": "CoBridge: Clear Context File"
      }
    ],
    "configuration": {
      "title": "CoBridge",
      "properties": {
        "AIContextSync.port": {
          "type": "number",
          "default": 3030,
          "description": "Port to listen for browser sync data."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.50.0",
    "typescript": "^4.9.5"
  }
}
