{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.0.1",
  "default_locale": "en",
  "description": "__MSG_extDescription__",
  "permissions": [
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",

    "*://*.googleusercontent.com/*",
    "*://gemini.google.com/*",
    "*://googleusercontent.com/*",
    "*://*.google.com/*",

    "*://www.doubao.com/*",

    "*://claude.ai/*",

    "*://chatgpt.com/*",

    "https://huggingface.co/*",
    "https://*.huggingface.co/*",
    "https://hf-mirror.com/*",
    "https://*.hf-mirror.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://gemini.google.com/*",
        "*://www.doubao.com/*",
        "*://claude.ai/*",
        "*://chatgpt.com/*"
      ],
      "js": ["src/content/contextSync.ts"]
    },
    {
      "matches": [
        "*://gemini.google.com/*",
        "*://www.doubao.com/*",
        "*://claude.ai/*",
        "*://chatgpt.com/*"
      ],
      "js": ["src/content/turnObserver.ts"],
      "run_at": "document_idle"
    }
  ]
}
